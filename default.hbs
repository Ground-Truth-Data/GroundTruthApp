<!DOCTYPE html>
<html lang="{{@site.locale}}">



<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{meta_title}}</title>
    <link rel="stylesheet" href="{{asset "built/screen.css"}}">

    {{ghost_head}}
</head>

<body class="{{body_class}}{{{block "body_class"}}} is-head-{{#match @custom.navigation_layout "Logo on the left"}}left-logo{{else match @custom.navigation_layout "Logo in the middle"}}middle-logo{{else}}stacked{{/match}}{{#match @custom.title_font "=" "Elegant serif"}} has-serif-title{{/match}}{{#match @custom.body_font "=" "Elegant serif"}} has-serif-body{{/match}}">
<!-- Google Tag Manager (noscript) -->
<noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-M3H973S4"
height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
<!-- End Google Tag Manager (noscript) -->
<div class="gh-site">

    <header id="gh-head" class="gh-head gh-outer">
        <div class="gh-head-inner gh-inner">
            <div class="gh-head-brand">
                <div class="gh-head-brand-wrapper">
                    <a class="gh-head-logo" href="http://localhost:2368">
                        <img src="http://localhost:2368/content/images/2024/11/2024-11-26-GT-Logo-Black.png" alt="Ground Truth Forest News">
                    </a>
                </div>
            </div>

            <nav class="gh-head-menu">
                <ul class="nav">
                    <li class="nav-home nav-current"><a href="http://localhost:2368/">Home</a></li>
                    <li class="nav-about"><a href="http://localhost:2368/about/">About</a></li>
                    <li class="nav-contact"><a href="http://localhost:2368/contact-info/">Contact</a></li>
                </ul>
            </nav>

            <div class="gh-head-actions">
                <button class="gh-search gh-icon-btn" aria-label="Search this site" data-ghost-search="">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" width="20" height="20">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                    </svg>
                </button>
                <button id="theme-toggle" class="gh-icon-btn" aria-label="Toggle Theme">🌓</button>
                <div class="gh-head-members">
                    <a class="gh-head-link gh-portal-close" href="#/portal/signin" data-portal="signin">Sign in</a>
                    <a class="gh-head-btn gh-btn gh-primary-btn gh-portal-close" href="#/portal/signup" data-portal="signup">Subscribe</a>
                </div>
            </div>
        </div>
    </header>

    {{#if @site.secondary_navigation}}
        <div class="gh-head-secondary">
            <div class="gh-inner">
                <h1 class="secondary-header-text">
                    EVIDENCE-BASED <span>FOREST NEWS</span>
                </h1>
                <nav class="gh-secondary-menu">
                    {{navigation type="secondary"}}
                </nav>
            </div>
        </div>
    {{/if}}

    <div class="site-content">
        {{{body}}}
    </div>

    <footer class="gh-foot{{#unless @site.secondary_navigation}} no-menu{{/unless}} gh-outer">
       <div class="gh-foot-inner gh-inner">
            <div class="gh-social-links" style="display: flex; justify-content: center; gap: 10px;">
        <a href="https://github.com/Ground-Truth-Data" target="_blank">
            <img src="https://groundtruth.app/content/images/2024/10/2024-10-20-Github--Icon-50X50-1.png" 
                width="50" height="50" loading="lazy"
                alt="Github icon">
        </a>
        <a href="https://www.facebook.com/GroundTruthData" target="_blank" rel="nofollow noreferrer noopener">
            <img src="https://ci3.googleusercontent.com/mail-sig/AIorK4z_0esdHusYht2SHyBrok-MwBUmo46MAS2aqFCTBSzwNVPsqVOqH6GpWUtJpuw4EQ_6Ss3Hltu7z-ml" 
                width="50" height="50" loading="lazy"
                alt="Facebook icon">
        </a>
        <a href="https://www.linkedin.com/company/ground-truth-data" target="_blank" rel="nofollow noreferrer noopener">
            <img src="https://ci3.googleusercontent.com/mail-sig/AIorK4xd2QQHKvwWhE5zC1cCelFNcrnOMcjTtpIPHrxQWw87HUpWOZ8pJzdxs3Y2MIQYBDllLr9KiiixsXz_" 
                width="50" height="50" loading="lazy"
                alt="LinkedIn icon">
        </a>
        <a href="https://bsky.app/profile/groundtruthdata.bsky.social" target="_blank" rel="nofollow noreferrer noopener">
            <img src="https://groundtruth.app/content/images/2024/10/2024-10-20-15-53-1.png" 
                width="50" height="50" loading="lazy"
                alt="Bluesky icon">
        </a>
        <a href="https://x.com/GroundTruthApp" target="_blank" rel="nofollow noreferrer noopener">
            <img src="https://groundtruth.app/content/images/2024/11/images-1.png" 
                width="50" height="50" loading="lazy"
                alt="X (formerly Twitter) icon">
        </a>
        <a href="https://mastodon.social/@GroundTruthData" target="_blank" rel="nofollow noreferrer noopener">
            <img src="https://groundtruth.app/content/images/2024/10/2024-10-20-Mastadon--Icon-50X50.png" 
                width="50" height="50" loading="lazy"
                alt="Mastodon icon">
        </a>
        <a href="https://medium.com/@GroundTruthData" target="_blank" rel="nofollow noreferrer noopener">
            <img src="https://groundtruth.app/content/images/2024/10/2024-10-20-Medium--Icon-50X50.jpg" 
                width="50" height="50" loading="lazy"
                alt="Medium icon">
        </a>
        <a href="https://app.wedonthavetime.org/profile/ground_truth_data" target="_blank" rel="nofollow noreferrer noopener">
            <img src="https://groundtruth.app/content/images/2024/10/2024-10-20-17-24.png" 
                width="50" height="50" loading="lazy"
                alt="We Don't Have Time icon">
        </a>
        <a href="https://ar.pinterest.com/GroundTruthData/" target="_blank" rel="nofollow noreferrer noopener" style="margin: 2px;">
            <img src="https://groundtruth.app/content/images/2024/10/Pinterest-logo.png" 
                width="50" height="50" loading="lazy"
                alt="Pinterest icon">
        </a>
</div>
        
        <!-- Copyright -->
        <div class="gh-copyright">
            
            {{@site.title}} © {{date format="YYYY"}}
        </div>

    
        <div class="gh-policy-links">
            <a href="https://groundtruth.app/content-policy/" target="_blank">Content Policy</a> |
            <a href="https://groundtruth.app/privacy-policy/" target="_blank">Privacy Policy</a>
        </div>

       
        <!-- Secondary Navigation if present -->
        {{#if @site.secondary_navigation}}
            <nav class="gh-foot-menu">
                {{navigation type="secondary"}}
            </nav>
        {{/if}}
    </div>
</footer>

</div>

{{#is "post, page"}}
    {{> "pswp"}}
{{/is}}

<script src="{{asset "built/main.min.js"}}"></script>
<script src="{{asset "js/scroll.js"}}"></script>

{{ghost_foot}}

</body>
</html>
