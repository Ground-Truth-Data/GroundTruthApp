{{!< default}}

<div class="gh-outer">
    <main class="site-main gh-inner">
        <div class="post-feed gh-feed">
            {{#foreach posts}}
                {{#if @first}}
                    {{> "loop" isFirst=true}}
                {{else}}
                    {{> "loop"}}
                {{/if}}
            {{/foreach}}
        </div>
    </main>
</div>