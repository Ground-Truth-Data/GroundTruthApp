{{!< default}}

<style>
    /* Hide header and secondary nav on this page only */
    .gh-head, .gh-head-secondary {
        display: none !important;
    }
</style>

<!-- Simple white X outside Ghost structure -->
<button onclick="history.back()" style="position: fixed; top: 20px; right: 20px; background: none; border: none; cursor: pointer; z-index: 9999;">
    <svg width="40" height="40" viewBox="0 0 24 24" style="fill: #ffffff;">
        <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/>
    </svg>
</button>

<div class="mobile-menu-page">
    <nav class="mobile-menu-nav">
        <!-- Primary Navigation -->
        <div class="mobile-menu-primary">
            {{navigation}}
        </div>

        <!-- Secondary Navigation -->
        {{#if @site.secondary_navigation}}
            <div class="mobile-menu-secondary">
                {{navigation type="secondary"}}
            </div>
        {{/if}}
    </nav>
</div>